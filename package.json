{
  "name": "software-architecture-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "test": "node --test tests/*.test.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "validate:links": "node scripts/validate-links.mjs",
    "validate:terminology": "node scripts/check-terminology.mjs",
    "verify": "npm run validate:data && npm run validate:links && npm run validate:terminology && npm test && npm run build"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.1.1",
    "marked": "^16.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "pagefind": "^1.5.2",
    "typescript": "^5.8.3"
  }
}
