---
import { projectIdentity } from "../config/identity";
interface Props { title?: string; description?: string; locale?: "tr" | "en" | "es"; }
const { title, description = projectIdentity.projectName.tr, locale = "tr" } = Astro.props;

const currentPath = Astro.url.pathname;
const getPathForLocale = (loc: string) => {
  const parts = currentPath.split("/").filter(Boolean);
  if (parts.length === 0) return `/${loc}/`;
  if (["tr", "en", "es"].includes(parts[0])) {
    parts[0] = loc;
  } else {
    parts.unshift(loc);
  }
  return "/" + parts.join("/") + "/";
};

const labels = locale === "tr"
  ? { home: "Ana sayfa", catalog: "Katalog", glossary: "Sözlük", compare: "Karşılaştır", decide: "Karar desteği", sources: "Kaynaklar", standards: "Standartlar", status: "Durum", registry: "Veri", graph: "Graf", requirements: "Gereksinimler", research:"Araştırma", author:"Yaz", manual:"Kullanım kılavuzu", skipLink: "İçeriğe geç" }
  : locale === "es"
  ? { home: "Inicio", catalog: "Catálogo", glossary: "Glosario", compare: "Comparar", decide: "Soporte de decisión", sources: "Fuentes", standards: "Estándares", status: "Estado", registry: "Datos", graph: "Grafo", requirements: "Requisitos", research:"Investigación", author:"Escribir", manual:"Manual de usuario", skipLink: "Saltar al contenido" }
  : { home: "Home", catalog: "Catalog", glossary: "Glossary", compare: "Compare", decide: "Decision support", sources: "Sources", standards: "Standards", status: "Status", registry: "Data", graph: "Graph", requirements: "Requirements", research:"Research", author:"Author", manual:"User manual", skipLink: "Skip to content" };
---
<!doctype html>
<html lang={locale} data-theme="dark" data-env={import.meta.env.MODE}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#0b1220" />
    <meta name="description" content={description} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/icons/atlas.svg" type="image/svg+xml" />
    <title>{title ? `${title} · ${projectIdentity.projectName[locale]}` : projectIdentity.projectName[locale]}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">{labels.skipLink}</a>
    <header class="topbar">
      <a class="brand" href={`/${locale}/`}>
        <span class="brand-mark">KA</span>
        <span><strong>{projectIdentity.projectName[locale]}</strong><small>Kenan AY · Knowledge system</small></span>
      </a>
      <nav aria-label="Ana gezinme">
        <a href={`/${locale}/`}>{labels.home}</a>
        <a href={`/${locale}/catalog/`}>{labels.catalog}</a>
        <a href={`/${locale}/glossary/`}>{labels.glossary}</a>
        <a href={`/${locale}/compare/`}>{labels.compare}</a>
        <a href={`/${locale}/decision/`}>{labels.decide}</a>
        <a href={`/${locale}/graph/`}>{labels.graph}</a>
        <a href={`/${locale}/research/`}>{labels.research}</a>
        <a href={`/${locale}/author/`}>{labels.author}</a>
        <a href={`/${locale}/requirements/`}>{labels.requirements}</a>
        <a href={`/${locale}/standards/`}>{labels.standards}</a>
        <a href={`/${locale}/registry/`}>{labels.registry}</a>
        <a href={`/${locale}/status/`}>{labels.status}</a>
      </nav>
      <div class="toolbar">
        <a class="locale-link" href={getPathForLocale("tr")} lang="tr">TR</a>
        <a class="locale-link" href={getPathForLocale("en")} lang="en">EN</a>
        <a class="locale-link" href={getPathForLocale("es")} lang="es">ES</a>
        <button id="theme-toggle" aria-label="Temayı değiştir">◐</button>
      </div>
    </header>
    <main id="main" data-pagefind-body><slot /></main>
    <footer>
      <div><strong>{projectIdentity.owner.name}</strong><br />{projectIdentity.owner.professionalTitle[locale]}</div>
      <div>{projectIdentity.roles[locale].join(" · ")}</div>
      <div><a class="footer-help" href={`/${locale}/docs/guide.user-manual/`}>{labels.manual}</a><br />v0.1.0 · Local-first</div>
    </footer>
    <script is:inline>
      const root = document.documentElement;
      const stored = localStorage.getItem("atlas-theme");
      root.dataset.theme = stored || (matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark");
      document.querySelector("#theme-toggle")?.addEventListener("click", () => {
        root.dataset.theme = root.dataset.theme === "dark" ? "light" : "dark";
        localStorage.setItem("atlas-theme", root.dataset.theme);
      });
      if (root.dataset.env === "production" && "serviceWorker" in navigator) addEventListener("load", () => navigator.serviceWorker.register("/sw.js"));
    </script>
  </body>
</html>

<style is:global>
  :root{--bg:#07101d;--panel:#101c2e;--panel2:#14243a;--text:#e8eef7;--muted:#96a7bd;--line:#253953;--accent:#5ee1c2;--accent2:#77a7ff;--warning:#f5c76b;--danger:#ff8f93;--shadow:0 18px 60px #0005;color-scheme:dark;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}
  :root[data-theme="light"]{--bg:#f4f7fb;--panel:#fff;--panel2:#edf3f8;--text:#152337;--muted:#597088;--line:#cfdae6;--accent:#007e6f;--accent2:#245fbe;--shadow:0 18px 50px #17355317;color-scheme:light}
  *{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:radial-gradient(circle at 15% -10%,color-mix(in srgb,var(--accent2) 18%,transparent),transparent 32%),var(--bg);color:var(--text);line-height:1.6}a{color:inherit}.skip-link{position:fixed;top:-4rem;left:1rem;z-index:99;background:var(--accent);color:#06120f;padding:.6rem 1rem;border-radius:.5rem}.skip-link:focus{top:1rem}
  .topbar{height:72px;display:flex;align-items:center;gap:2rem;padding:0 clamp(1rem,4vw,4rem);border-bottom:1px solid var(--line);background:color-mix(in srgb,var(--bg) 88%,transparent);backdrop-filter:blur(16px);position:sticky;top:0;z-index:20}.brand{display:flex;align-items:center;gap:.75rem;text-decoration:none;min-width:max-content}.brand-mark{display:grid;place-items:center;width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#07101d;font-weight:900}.brand strong{font-size:.9rem;display:block}.brand small{display:block;color:var(--muted);font-size:.66rem}.topbar nav{display:flex;gap:.25rem;overflow:auto}.topbar nav a{padding:.45rem .65rem;text-decoration:none;color:var(--muted);font-size:.84rem;border-radius:.5rem;white-space:nowrap}.topbar nav a:hover,.topbar nav a:focus-visible{background:var(--panel2);color:var(--text)}.toolbar{margin-left:auto;display:flex;align-items:center;gap:.25rem}.locale-link{font-size:.72rem;color:var(--muted);text-decoration:none;padding:.35rem}.locale-link:hover,.locale-link:focus{color:var(--accent)}.toolbar button,button,.button{border:1px solid var(--line);background:var(--panel2);color:var(--text);padding:.65rem .9rem;border-radius:.65rem;cursor:pointer;font:inherit}.button.primary,button.primary{background:var(--accent);border-color:var(--accent);color:#06120f;font-weight:750;text-decoration:none}
  main{min-height:calc(100vh - 160px)}.shell{width:min(1180px,calc(100% - 2rem));margin:auto;padding:3rem 0}.hero{padding:5.5rem 0 3.5rem;display:grid;grid-template-columns:1.35fr .65fr;gap:3rem;align-items:center}.eyebrow{color:var(--accent);font-weight:800;letter-spacing:.14em;text-transform:uppercase;font-size:.75rem}.hero h1{font-size:clamp(2.5rem,6vw,5.5rem);line-height:.98;letter-spacing:-.055em;margin:.7rem 0 1.4rem;max-width:850px}.lead{font-size:1.12rem;color:var(--muted);max-width:700px}.actions{display:flex;gap:.8rem;flex-wrap:wrap;margin-top:1.8rem}.metric-panel{background:linear-gradient(150deg,var(--panel2),var(--panel));border:1px solid var(--line);border-radius:1.25rem;padding:1.2rem;box-shadow:var(--shadow)}.metric{display:flex;justify-content:space-between;padding:.9rem;border-bottom:1px solid var(--line)}.metric:last-child{border:0}.metric strong{font-size:1.4rem;color:var(--accent)}
  h1,h2,h3{line-height:1.18}h2{font-size:clamp(1.55rem,3vw,2.35rem);letter-spacing:-.025em}.section-head{display:flex;justify-content:space-between;align-items:end;gap:2rem;margin:2rem 0 1.2rem}.muted{color:var(--muted)}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.card{border:1px solid var(--line);border-radius:1rem;padding:1.25rem;background:color-mix(in srgb,var(--panel) 94%,transparent);text-decoration:none;transition:.2s}.card:hover{transform:translateY(-3px);border-color:var(--accent2);box-shadow:var(--shadow)}.card h3{margin:.2rem 0}.card p{color:var(--muted);font-size:.92rem}.tag,.status,.badge{display:inline-flex;align-items:center;border:1px solid var(--line);border-radius:100px;padding:.15rem .55rem;font-size:.72rem;color:var(--muted);margin:.15rem}.status.reviewed,.status.verified,.badge.is-current,.badge.is-original,.badge.is-synced{color:var(--accent);border-color:color-mix(in srgb,var(--accent) 45%,var(--line))}.status.draft,.status.review-required,.badge.needs-review,.badge.is-outdated{color:var(--warning);border-color:color-mix(in srgb,var(--warning) 50%,var(--line))}.badge.is-obsolete,.badge.is-withdrawn{color:var(--danger);border-color:color-mix(in srgb,var(--danger) 50%,var(--line))}.badge-kind{opacity:.72;margin-right:.28rem;font-size:.62rem;text-transform:uppercase;letter-spacing:.05em}.badge-group{display:flex;gap:.2rem;flex-wrap:wrap;margin:.6rem 0}.registry-table{width:100%;border-collapse:collapse;font-size:.88rem}.registry-table th,.registry-table td{text-align:left;vertical-align:top;padding:.7rem;border-bottom:1px solid var(--line)}
  .page-grid{display:grid;grid-template-columns:240px minmax(0,1fr);gap:2rem}.sidebar{position:sticky;top:92px;align-self:start}.sidebar a{display:block;padding:.45rem .7rem;border-left:2px solid var(--line);color:var(--muted);text-decoration:none}.sidebar a:hover{color:var(--text);border-color:var(--accent)}.content{max-width:820px}.content h2{margin-top:2.5rem}.content blockquote{border-left:3px solid var(--warning);margin:1.5rem 0;padding:.7rem 1rem;background:var(--panel);color:var(--muted)}.content code{background:var(--panel2);padding:.15rem .35rem;border-radius:.3rem}.metadata{display:flex;gap:.35rem;flex-wrap:wrap;margin:1rem 0 2rem}.source-list{list-style:none;padding:0}.source-list li{padding:1rem;border-bottom:1px solid var(--line)}
  label{display:block;color:var(--muted);font-size:.82rem;margin-bottom:.3rem}input,select,textarea{width:100%;background:var(--panel);color:var(--text);border:1px solid var(--line);border-radius:.65rem;padding:.75rem;font:inherit}input:focus,select:focus,textarea:focus{outline:2px solid var(--accent2);outline-offset:1px}.form-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem}.field{margin-bottom:1rem}.searchbar{position:relative;margin:1.2rem 0}.searchbar input{font-size:1rem;padding:1rem 1rem 1rem 2.8rem}.searchbar:before{content:"⌕";position:absolute;left:1rem;top:.55rem;font-size:1.5rem;color:var(--muted)}.empty{padding:3rem;text-align:center;border:1px dashed var(--line);border-radius:1rem;color:var(--muted)}
  footer{border-top:1px solid var(--line);margin-top:5rem;padding:2rem clamp(1rem,4vw,4rem);display:flex;justify-content:space-between;gap:2rem;color:var(--muted);font-size:.78rem}dialog{max-width:620px;border:1px solid var(--line);border-radius:1rem;background:var(--panel);color:var(--text);padding:1.5rem;box-shadow:var(--shadow)}dialog::backdrop{background:#000a}
  @media(max-width:900px){.topbar{height:auto;padding:.7rem 1rem;flex-wrap:wrap;gap:.5rem}.topbar nav{order:3;width:100%}.hero{grid-template-columns:1fr;padding-top:3rem}.grid{grid-template-columns:1fr 1fr}.page-grid{grid-template-columns:1fr}.sidebar{position:static}.form-grid{grid-template-columns:1fr}}
  @media(max-width:560px){.grid{grid-template-columns:1fr}.brand strong{font-size:.78rem}.hero h1{font-size:2.7rem}footer{flex-direction:column}.shell{width:min(100% - 1.2rem,1180px)}}
  @media(prefers-reduced-motion:reduce){*,*::before,*::after{scroll-behavior:auto!important;transition:none!important;animation:none!important}}
  @media print{.topbar,.sidebar,.actions,footer{display:none}.shell{width:100%;padding:0}.page-grid{display:block}:root{--bg:#fff;--text:#111;--muted:#444;--panel:#fff;--line:#bbb}}
</style>
