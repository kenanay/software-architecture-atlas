---
import BaseLayout from "../../layouts/BaseLayout.astro";
import sources from "../../../data/sources/sources.json";
import taxonomyData from "../../../data/taxonomy/taxonomy.json";
export function getStaticPaths(){return ["tr","en","es"].map(locale=>({params:{locale}}));}
const {locale}=Astro.params as {locale:"tr"|"en"|"es"};
const taxonomy = taxonomyData as Array<(typeof taxonomyData)[number] & { label: Record<"tr"|"en"|"es", string> }>;
const c={tr:{eyebrow:"Şema destekli yazarlık",title:"Araştırma taslağı editörü",lead:"Taslağı tarayıcıda saklayın, kaynaklarla bağlayın, önizleyin ve kanonik Markdown olarak dışa aktarın.",save:"Taslağı sakla",download:"Markdown indir",preview:"Güvenli önizleme",body:"Teknik içerik"},en:{eyebrow:"Schema-aware authoring",title:"Research draft editor",lead:"Store a draft in the browser, connect sources, preview it, and export canonical Markdown.",save:"Save draft",download:"Download Markdown",preview:"Safe preview",body:"Technical content"},es:{eyebrow:"Autoría con esquema",title:"Editor de borradores",lead:"Guarde el borrador en el navegador, vincule fuentes, previsualice y exporte Markdown canónico.",save:"Guardar borrador",download:"Descargar Markdown",preview:"Vista previa segura",body:"Contenido técnico"}}[locale];
---
<BaseLayout title={c.title} locale={locale}><div class="shell"><div class="eyebrow">{c.eyebrow}</div><h1>{c.title}</h1><p class="lead">{c.lead}</p><div class="page-grid" style="grid-template-columns:minmax(0,1fr) minmax(320px,1fr)"><form id="author-form" class="card" style="transform:none"><div class="form-grid"><div class="field"><label for="canonical">Canonical ID</label><input id="canonical" required placeholder="architecture.event-sourcing" /></div><div class="field"><label for="doc-type">Type</label><select id="doc-type"><option>architecture</option><option>concept</option><option>programming-language</option><option>standard</option><option>research-note</option><option>academic-source-summary</option></select></div><div class="field"><label for="title">Title</label><input id="title" required /></div><div class="field"><label for="category">Category</label><select id="category">{taxonomy.map(item=><option value={item.id}>{item.label[locale] || item.label.en}</option>)}</select></div><div class="field"><label for="source-ids">Sources</label><select id="source-ids" multiple size="5">{sources.map(source=><option value={source.id}>{source.title}</option>)}</select></div><div class="field"><label for="status">Editorial status</label><select id="status"><option>draft</option><option>review-required</option><option>reviewed</option></select></div></div><div class="field"><label for="summary">Summary</label><textarea id="summary" rows="2"></textarea></div><div class="field"><label for="body">{c.body}</label><textarea id="body" rows="18" placeholder="## Problem\n\n## Evidence\n\n## Trade-offs"></textarea></div><div class="actions"><button class="primary" type="submit">{c.save}</button><button id="download-draft" type="button">{c.download}</button></div><p id="author-message" role="status" aria-live="polite"></p></form><section><h2>{c.preview}</h2><article class="card" style="transform:none"><h3 id="preview-title">—</h3><p id="preview-summary" class="muted"></p><pre id="preview-body" style="white-space:pre-wrap"></pre></article></section></div></div>
<script is:inline define:vars={{ locale }}>
const ids=['canonical','doc-type','title','category','source-ids','status','summary','body'];const field=id=>document.querySelector(`#${id}`);const key=`atlas:author:${locale}`;const values=()=>Object.fromEntries(ids.map(id=>[id,id==='source-ids'?[...field(id).selectedOptions].map(x=>x.value):field(id).value]));function restore(){try{const data=JSON.parse(localStorage.getItem(key)||'{}');ids.forEach(id=>{if(data[id]===undefined)return;if(id==='source-ids')[...field(id).options].forEach(x=>x.selected=data[id].includes(x.value));else field(id).value=data[id];});}catch{}}function preview(){const data=values();document.querySelector('#preview-title').textContent=data.title||'—';document.querySelector('#preview-summary').textContent=data.summary;document.querySelector('#preview-body').textContent=data.body;}function markdown(){const d=values(),today=new Date().toISOString().slice(0,10),canonical=d.canonical||'draft.example';return `---\nid: ${canonical}.${locale}\ntype: ${d['doc-type']}\ntitle: { tr: ${JSON.stringify(locale==='tr'?d.title:'')}, en: ${JSON.stringify(locale==='en'?d.title:'')}, es: ${JSON.stringify(locale==='es'?d.title:'')} }\nsummary: { tr: ${JSON.stringify(locale==='tr'?d.summary:'')}, en: ${JSON.stringify(locale==='en'?d.summary:'')}, es: ${JSON.stringify(locale==='es'?d.summary:'')} }\nstatus: ${d.status}\nmaturity: active\ncategories: [${d.category}]\ntags: []\nlocale: ${locale}\ntranslationKey: ${canonical}\ncanonicalId: ${canonical}\ntranslationStatus: original\ntranslationMethod: original\nversion: 0.1.0\nlastReviewedAt: ${today}\nsources: [${d['source-ids'].join(', ')}]\nrelated: []\ncontributors:\n  - personId: person.kenan-ay\n    roles: [researcher, technical-author]\nqualityAttributes: []\napplicableDomains: []\n---\n\n${d.body}\n`;};restore();preview();document.querySelector('#author-form').addEventListener('input',preview);document.querySelector('#author-form').addEventListener('submit',e=>{e.preventDefault();localStorage.setItem(key,JSON.stringify(values()));document.querySelector('#author-message').textContent='Draft saved locally.';});document.querySelector('#download-draft').addEventListener('click',()=>{const d=values(),a=document.createElement('a');a.href=URL.createObjectURL(new Blob([markdown()],{type:'text/markdown'}));a.download=`${d.canonical||'atlas-draft'}.${locale}.md`;a.click();URL.revokeObjectURL(a.href);});
</script></BaseLayout>
