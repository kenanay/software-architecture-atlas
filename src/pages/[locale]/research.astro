---
import BaseLayout from "../../layouts/BaseLayout.astro";
import sources from "../../../data/sources/sources.json";
import claims from "../../../data/claims/claims.json";
export function getStaticPaths(){return ["tr","en","es"].map(locale=>({params:{locale}}));}
const {locale}=Astro.params as {locale:"tr"|"en"|"es"};
const t={tr:{eyebrow:"Araştırma çalışma alanı",title:"Kaynak → iddia → sentez",lead:"Okuma kuyruğunuzu yönetin, kanıt konumlarını inceleyin ve doğrulanmış iddiaları teknik belgelere dönüştürün.",queue:"Kaynak okuma kuyruğu",claims:"İddia–kanıt matrisi",status:"Okuma durumu",locator:"Konum",role:"Rol"},en:{eyebrow:"Research workspace",title:"Source → claim → synthesis",lead:"Manage the reading queue, inspect evidence locators, and turn verified claims into technical documents.",queue:"Source reading queue",claims:"Claim–evidence matrix",status:"Reading status",locator:"Locator",role:"Role"},es:{eyebrow:"Espacio de investigación",title:"Fuente → afirmación → síntesis",lead:"Gestione la cola de lectura, revise ubicaciones de evidencia y convierta afirmaciones verificadas en documentos técnicos.",queue:"Cola de lectura",claims:"Matriz de afirmaciones y evidencia",status:"Estado de lectura",locator:"Ubicación",role:"Rol"}}[locale];
const statement=(claim:any)=>claim.statement[locale]||claim.statement.en;
---
<BaseLayout title={t.title} locale={locale}><div class="shell"><div class="eyebrow">{t.eyebrow}</div><h1>{t.title}</h1><p class="lead">{t.lead}</p>
<section><div class="section-head"><h2>{t.queue}</h2><span class="tag">{sources.length}</span></div><div class="grid">{sources.map(source=><article class="card"><span class="tag">{source.type}</span><h3><a href={source.url}>{source.title}</a></h3><p>{source.publisher} · {source.publication_date}</p><label>{t.status}<select class="reading-status" data-source={source.id}><option value="queued">queued</option><option value="reading">reading</option><option value="read">read</option><option value="synthesized">synthesized</option></select></label></article>)}</div></section>
<section><div class="section-head"><h2>{t.claims}</h2><span class="tag">{claims.length}</span></div>{claims.map(claim=><article class="card" style="transform:none;margin-bottom:1rem"><div class="badge-group"><span class="badge">{claim.confidence}</span><span class="badge">{claim.status}</span><code>{claim.id}</code></div><p>{statement(claim)}</p><ul>{claim.evidence.map(e=><li><code>{e.sourceId}</code> · {t.locator}: {e.locator} · {t.role}: {e.role}</li>)}</ul><a href={`/${locale}/docs/${claim.documentCanonicalId}/`}>{claim.documentCanonicalId} →</a></article>)}</section></div>
<script is:inline>document.querySelectorAll('.reading-status').forEach(select=>{const key=`atlas:reading:${select.dataset.source}`;select.value=localStorage.getItem(key)||'queued';select.addEventListener('change',()=>localStorage.setItem(key,select.value));});</script></BaseLayout>
