---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
const docs = (await getCollection("documents")).sort((a,b) => a.data.title[a.data.locale].localeCompare(b.data.title[b.data.locale], a.data.locale));
const payload = docs.map(d => ({ id:d.data.id, locale:d.data.locale, title:d.data.title[d.data.locale], alternateTitle:d.data.title[d.data.locale === "tr" ? "en" : "tr"], summary:d.data.summary[d.data.locale], categories:d.data.categories, tags:d.data.tags, type:d.data.type, status:d.data.status }));
---
<BaseLayout title="Katalog">
  <div class="shell">
    <div class="eyebrow">Katalog</div><h1>Bilgi tabanını keşfedin</h1><p class="lead">Başlık, İngilizce karşılık, etiket ve özet içinde arayın; belge türüne veya durumuna göre daraltın.</p>
    <div class="searchbar"><input id="search" type="search" placeholder="Örn. Rust, modüler, RAG…" autocomplete="off" /></div>
    <div class="form-grid">
      <div class="field"><label for="locale">Belge dili</label><select id="locale"><option value="">Türkçe + English</option><option value="tr">Türkçe</option><option value="en">English</option></select></div>
      <div class="field"><label for="category">Kategori</label><select id="category"><option value="">Tüm kategoriler</option><option value="guide">Sistem rehberi</option><option value="languages">Programlama dilleri</option><option value="architectures">Mimari stiller</option><option value="ai">Yapay zekâ</option></select></div>
      <div class="field"><label for="status">Belge durumu</label><select id="status"><option value="">Tüm durumlar</option><option value="reviewed">İncelenmiş</option><option value="review-required">İnceleme gerekli</option><option value="draft">Taslak</option></select></div>
    </div>
    <p id="count" class="muted"></p><div id="results" class="grid"></div>
    <section id="fulltext-section" hidden style="margin-top:3rem"><div class="section-head"><div><h2>Tam metin sonuçları</h2><p class="muted">Pagefind, statik üretim sırasında belge gövdelerini indeksler.</p></div><span id="fulltext-count" class="tag"></span></div><div id="fulltext-results" class="grid"></div></section>
  </div>
  <script is:inline define:vars={{ payload }}>
    const q = document.querySelector("#search"), locale = document.querySelector("#locale"), category = document.querySelector("#category"), status = document.querySelector("#status"), results = document.querySelector("#results"), count = document.querySelector("#count");
    const params = new URLSearchParams(location.search); category.value = params.get("category") || "";
    const escapeHtml = value => value.replace(/[&<>'"]/g, char => ({"&":"&amp;","<":"&lt;",">":"&gt;","'":"&#39;",'"':"&quot;"})[char]);
    let searchToken=0;
    async function fullText(term){const token=++searchToken,section=document.querySelector("#fulltext-section"),container=document.querySelector("#fulltext-results"),badge=document.querySelector("#fulltext-count");if(term.length<2){section.hidden=true;return;}try{const pagefind=await import("/pagefind/pagefind.js");const response=await pagefind.search(term);const entries=await Promise.all(response.results.slice(0,12).map(item=>item.data()));if(token!==searchToken)return;badge.textContent=`${response.results.length} eşleşme`;container.innerHTML=entries.map(item=>`<a class="card" href="${item.url}"><span class="tag">full text</span><h3>${escapeHtml(item.meta.title||"Belge")}</h3><p>${item.excerpt}</p></a>`).join("");section.hidden=false;}catch{section.hidden=true;}}
    function render(){ const term=q.value.toLocaleLowerCase("tr").trim(); const filtered=payload.filter(d => (!term || `${d.title} ${d.alternateTitle} ${d.summary} ${d.tags.join(" ")}`.toLocaleLowerCase("tr").includes(term)) && (!locale.value || d.locale===locale.value) && (!category.value || d.categories.includes(category.value)) && (!status.value || d.status===status.value)); count.textContent=`${filtered.length} belge gösteriliyor`; results.innerHTML=filtered.length?filtered.map(d=>`<a class="card" href="/docs/${encodeURIComponent(d.id)}/"><span class="tag">${escapeHtml(d.locale.toUpperCase())}</span><span class="status ${d.status}">${escapeHtml(d.status)}</span><span class="tag">${escapeHtml(d.type)}</span><h3>${escapeHtml(d.title)}</h3><p>${escapeHtml(d.summary)}</p></a>`).join(""):`<div class="empty" style="grid-column:1/-1">Bu ölçütlerle eşleşen belge bulunamadı.</div>`;fullText(term); }
    [q,locale,category,status].forEach(el=>el.addEventListener("input",render)); render();
  </script>
</BaseLayout>
