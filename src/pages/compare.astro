---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
const docs = (await getCollection("documents")).map(d=>({id:d.data.id,canonicalId:d.data.canonicalId,locale:d.data.locale,title:d.data.title[d.data.locale],otherTitle:d.data.title[d.data.locale === "tr" ? "en" : "tr"],summary:d.data.summary[d.data.locale],type:d.data.type,status:d.data.status,maturity:d.data.maturity,translationStatus:d.data.translationStatus,version:d.data.version,categories:d.data.categories,tags:d.data.tags,qualityAttributes:d.data.qualityAttributes,applicableDomains:d.data.applicableDomains,sources:d.data.sources}));
---
<BaseLayout title="Teknoloji Karşılaştırması">
  <div class="shell"><div class="eyebrow">Yan yana değerlendirme</div><h1>Bilgi profillerini karşılaştırın</h1><p class="lead">Tüm belge türlerini Türkçe, İngilizce veya birlikte karşılaştırın; editoryal durum ile teknoloji olgunluğunu ayrı görün.</p>
    <div class="field" style="max-width:320px"><label for="compare-locale">Belge dili</label><select id="compare-locale"><option value="all">Türkçe + English</option><option value="tr">Türkçe</option><option value="en">English</option></select></div>
    <div class="form-grid"><div><label for="left">Birinci profil</label><select id="left"></select></div><div><label for="right">İkinci profil</label><select id="right"></select></div></div>
    <div id="comparison" class="grid" style="grid-template-columns:1fr 1fr;margin-top:2rem"></div>
  </div>
  <script is:inline define:vars={{ docs }}>
    const left=document.querySelector("#left"),right=document.querySelector("#right"),locale=document.querySelector("#compare-locale"),out=document.querySelector("#comparison");
    const esc=v=>String(v).replace(/[&<>'"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;","'":"&#39;",'"':"&quot;"})[c]);
    const card=d=>`<article class="card" style="transform:none"><div class="badge-group"><span class="badge"><span class="badge-kind">Dil</span>${esc(d.locale.toUpperCase())}</span><span class="badge ${["reviewed","verified"].includes(d.status)?"is-current":"needs-review"}"><span class="badge-kind">Editoryal</span>${esc(d.status)}</span><span class="badge"><span class="badge-kind">Olgunluk</span>${esc(d.maturity)}</span><span class="badge ${["reviewed","original"].includes(d.translationStatus)?"is-synced":"is-outdated"}"><span class="badge-kind">Çeviri</span>${esc(d.translationStatus)}</span></div><h2>${esc(d.title)}</h2><p class="muted">${esc(d.otherTitle)}</p><p>${esc(d.summary)}</p><h3>Profil</h3><p><strong>Tür:</strong> ${esc(d.type)}<br><strong>Canonical ID:</strong> ${esc(d.canonicalId)}<br><strong>Sürüm:</strong> ${esc(d.version)}</p><h3>Kalite öznitelikleri</h3><p>${d.qualityAttributes.map(x=>`<span class="tag">${esc(x)}</span>`).join("")||"—"}</p><h3>Uygulanabilir alanlar</h3><p>${d.applicableDomains.map(x=>`<span class="tag">${esc(x)}</span>`).join("")||"—"}</p><h3>Kategoriler ve kaynaklar</h3><p>${d.categories.map(x=>`<span class="tag">${esc(x)}</span>`).join("")}</p><p>${d.sources.map(x=>`<span class="tag">${esc(x)}</span>`).join("")||"Kaynak kaydı yok"}</p><a href="/docs/${encodeURIComponent(d.id)}/">Belgeyi aç →</a></article>`;
    function options(){const filtered=docs.filter(d=>locale.value==="all"||d.locale===locale.value);const previous=[left.value,right.value];[left,right].forEach((select,index)=>{select.innerHTML=filtered.map(d=>`<option value="${esc(d.id)}">[${d.locale.toUpperCase()}] ${esc(d.title)} · ${esc(d.type)}</option>`).join("");if(filtered.some(d=>d.id===previous[index]))select.value=previous[index];});if(right.options.length>1&&right.value===left.value)right.selectedIndex=1;render();}
    function render(){out.innerHTML=[left.value,right.value].map(id=>docs.find(d=>d.id===id)).filter(Boolean).map(card).join("");}[left,right].forEach(el=>el.addEventListener("change",render));locale.addEventListener("change",options);options();
  </script>
</BaseLayout>
