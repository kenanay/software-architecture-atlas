---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Mimari Karar Desteği">
  <div class="shell"><div class="eyebrow">Gerekçeli değerlendirme</div><h1>Proje karar desteği</h1><p class="lead">Bu araç kesin hüküm vermez; gereksinimlerinize göre adayları, ödünleşimleri ve riskleri görünür kılar.</p>
    <div class="page-grid" style="grid-template-columns:minmax(0,1fr) minmax(320px,.8fr)">
      <form id="decision-form" class="card" style="transform:none">
        <div class="form-grid"><div class="field"><label for="domain">Uygulama alanı</label><select id="domain"><option value="web">Web</option><option value="mobile">Mobil</option><option value="desktop">Masaüstü</option><option value="embedded">Gömülü sistem ve IoT</option><option value="ai">Yapay zekâ</option><option value="games">Oyun sistemleri</option><option value="networks">Ağ sistemleri</option><option value="server-cloud">Sunucu, bulut ve dağıtık</option><option value="data">Veri sistemleri</option><option value="graphics">Grafik ve medya</option><option value="security">Güvenlik sistemleri</option></select></div><div class="field"><label for="scale">Kullanıcı/işlem ölçeği</label><select id="scale"><option value="small">Küçük</option><option value="medium">Orta</option><option value="large">Büyük</option></select></div><div class="field"><label for="experience">Ekip deneyimi</label><select id="experience"><option value="beginner">Başlangıç</option><option value="mixed" selected>Karma</option><option value="expert">Uzman</option></select></div><div class="field"><label for="data-volume">Veri hacmi</label><select id="data-volume"><option value="low">Düşük</option><option value="medium">Orta</option><option value="high">Yüksek</option></select></div><div class="field"><label for="latency">Gecikme sınırı</label><select id="latency"><option value="relaxed">Esnek</option><option value="interactive">Etkileşimli</option><option value="realtime">Gerçek zamanlı</option></select></div><div class="field"><label for="deployment">Dağıtım ortamı</label><select id="deployment"><option value="local">Yerel</option><option value="on-premise">On-premise</option><option value="cloud">Bulut</option><option value="edge">Edge</option></select></div><div class="field"><label for="security-level">Güvenlik seviyesi</label><select id="security-level"><option value="standard">Standart</option><option value="high">Yüksek</option><option value="regulated">Düzenlemeye tabi</option></select></div><div class="field"><label for="license">Lisans kısıtı</label><select id="license"><option value="none">Yok</option><option value="permissive-only">Yalnızca izin verici</option><option value="commercial-allowed">Ticari uygun</option></select></div></div>
        <label><input style="width:auto" id="offline" type="checkbox" /> Çevrimdışı çalışma gerekli</label><label><input style="width:auto" id="realtime" type="checkbox" /> Gerçek zaman gereksinimi var</label><label><input style="width:auto" id="safety" type="checkbox" /> Güvenlik kritik sistem</label><label><input style="width:auto" id="ai-required" type="checkbox" /> AI/ML bileşeni gerekli</label><label><input style="width:auto" id="hardware" type="checkbox" /> Donanıma doğrudan erişim gerekli</label>
        <fieldset><legend>Karar ağırlıkları</legend><div class="form-grid"><div><label for="weight-performance">Performans</label><input id="weight-performance" type="range" min="1" max="5" value="3" /></div><div><label for="weight-security">Güvenlik</label><input id="weight-security" type="range" min="1" max="5" value="3" /></div><div><label for="weight-maintainability">Bakım</label><input id="weight-maintainability" type="range" min="1" max="5" value="3" /></div><div><label for="weight-scalability">Ölçeklenebilirlik</label><input id="weight-scalability" type="range" min="1" max="5" value="3" /></div><div><label for="weight-cost">Maliyet</label><input id="weight-cost" type="range" min="1" max="5" value="3" /></div></div></fieldset>
        <div class="actions"><button class="primary" type="submit">Adayları değerlendir</button><button id="download-adr" type="button" disabled>ADR indir</button></div>
      </form>
      <div id="decision-result" class="card" style="transform:none"><div class="eyebrow">Sonuç alanı</div><h2>Girdilerinizi değerlendirin</h2><p class="muted">Öneriler, kapsamlı mühendislik incelemesinin yerini almaz.</p></div>
    </div>
  </div>
  <script>
    import { evaluateDecision } from "../modules/decision-support/domain/evaluate";
    import type { DecisionInput } from "../core/domain/models";
    import sources from "../../data/sources/sources.json";
    let latest:any;
    const form=document.querySelector<HTMLFormElement>("#decision-form")!, result=document.querySelector("#decision-result")!, download=document.querySelector<HTMLButtonElement>("#download-adr")!;
    const val=(id:string)=>(document.querySelector<HTMLSelectElement>(`#${id}`)!).value;
    form.addEventListener("submit",e=>{e.preventDefault();const checked=(id:string)=>(document.querySelector<HTMLInputElement>(`#${id}`)!).checked;const weight=(id:string)=>Number((document.querySelector<HTMLInputElement>(`#weight-${id}`)!).value);const input:DecisionInput={domain:val("domain") as any,scale:val("scale") as any,teamExperience:val("experience") as any,dataVolume:val("data-volume") as any,latency:val("latency") as any,deployment:val("deployment") as any,securityLevel:val("security-level") as any,licenseConstraint:val("license") as any,offline:checked("offline"),realtime:checked("realtime"),safetyCritical:checked("safety"),aiRequired:checked("ai-required"),hardwareAccess:checked("hardware"),weights:{performance:weight("performance"),security:weight("security"),maintainability:weight("maintainability"),scalability:weight("scalability"),cost:weight("cost")}};latest={input,output:evaluateDecision(input),createdAt:new Date().toISOString()};const o=latest.output;const evidence=o.evidence.map((item:any)=>{const source=sources.find((candidate:any)=>candidate.id===item.sourceId);return `<li>${item.claim}<br><small>Kalite: ${item.qualityAttributes.join(", ")} · <a href="${source?.url||"#"}">${source?.title||item.sourceId}</a></small></li>`}).join("");const ranked=(items:any[])=>`<ol>${items.map(x=>`<li><strong>${x.name}: ${x.score}/100</strong><br><small>${x.reasons.join(" · ")}</small></li>`).join("")}</ol>`;result.innerHTML=`<div class="eyebrow">Güven: ${o.confidence}</div><p class="muted">${o.confidenceReason}</p><h2>Puanlı dil adayları</h2>${ranked(o.scoredLanguages)}<h2>Puanlı mimari adayları</h2>${ranked(o.scoredArchitectures)}<h3>Alternatif koşulları</h3><ul>${o.alternatives.map((x:any)=>`<li><strong>${x.option}:</strong> ${x.preferWhen}</li>`).join("")}</ul><h3>Veri ve dağıtım</h3><p>${o.dataSystems.join(" · ")}<br>Dağıtım: ${o.deploymentModel}</p><h3>Test stratejisi</h3><ul>${o.testStrategy.map((x:string)=>`<li>${x}</li>`).join("")}</ul><h3>Gerekçe</h3><ul>${o.rationale.map((x:string)=>`<li>${x}</li>`).join("")}</ul><h3>Kanıt ve kalite öznitelikleri</h3><ul>${evidence}</ul><h3>Riskler</h3>${o.risks.length?`<ul>${o.risks.map((x:string)=>`<li>${x}</li>`).join("")}</ul>`:"<p>Ön değerlendirmede özel risk eklenmedi.</p>"}<h3>Uygun olmayan seçenekler</h3>${o.unsuitableOptions.length?`<ul>${o.unsuitableOptions.map((x:string)=>`<li>${x}</li>`).join("")}</ul>`:"<p>Bağlama özel dışlama üretilmedi.</p>"}`;download.disabled=false;});
    download.addEventListener("click",()=>{const o=latest.output;const text=`# ADR: Teknoloji ve Mimari Ön Değerlendirmesi\n\nTarih: ${latest.createdAt}\nDurum: Taslak\nHazırlayan: Kenan AY\nGüven: ${o.confidence} — ${o.confidenceReason}\n\n## Girdiler\n\n\`\`\`json\n${JSON.stringify(latest.input,null,2)}\n\`\`\`\n\n## Aday diller\n\n${o.languages.join(", ")}\n\n## Aday mimariler\n\n${o.architectures.join(", ")}\n\n## Alternatif koşulları\n\n${o.alternatives.map((x:any)=>`- **${x.option}:** ${x.preferWhen}`).join("\n")}\n\n## Gerekçe\n\n${o.rationale.map((x:string)=>`- ${x}`).join("\n")}\n\n## Kanıt ve kalite öznitelikleri\n\n${o.evidence.map((x:any)=>`- ${x.claim} — ${x.sourceId} — ${x.qualityAttributes.join(", ")}`).join("\n")}\n\n## Test stratejisi\n\n${o.testStrategy.map((x:string)=>`- ${x}`).join("\n")}\n\n## Riskler\n\n${o.risks.map((x:string)=>`- ${x}`).join("\n")||"- Ayrıntılı risk analizi gerekli."}`;const a=document.createElement("a");a.href=URL.createObjectURL(new Blob([text],{type:"text/markdown"}));a.download="architecture-decision-record.md";a.click();URL.revokeObjectURL(a.href);});
  </script>
</BaseLayout>
