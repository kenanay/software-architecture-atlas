---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import sources from "../../../data/sources/sources.json";
export async function getStaticPaths() {
  const docs = await getCollection("documents");
  return docs.map(doc => ({ params: { id: doc.data.id }, props: { doc, allDocs: docs } }));
}
const { doc, allDocs } = Astro.props;
const { Content, headings } = await render(doc);
const locale = doc.data.locale;
const sourceRecords = sources.filter(source => doc.data.sources.includes(source.id));
const translation = allDocs.find((candidate:any) => candidate.data.translationKey === doc.data.translationKey && candidate.data.locale !== locale);
const translationOutdated = translation && translation.data.version !== doc.data.version;
---
<BaseLayout title={doc.data.title[locale]} description={doc.data.summary[locale]} locale={locale}>
  <div class="shell page-grid">
    <aside class="sidebar">
      <div class="eyebrow">{locale === "tr" ? "Bu belgede" : "On this page"}</div>
      {headings.filter((h:any) => h.depth <= 3).map((h:any) => <a href={`#${h.slug}`}>{h.text}</a>)}
      {translation && <a href={`/docs/${translation.data.id}/`} style="margin-top:1rem">{locale === "tr" ? "English version →" : "Türkçe sürüm →"}</a>}
    </aside>
    <article class="content" data-document-id={doc.data.id}>
      <div class="eyebrow">{doc.data.type}</div><h1>{doc.data.title[locale]}</h1><p class="lead">{doc.data.summary[locale]}</p>
      <div class="metadata"><span class={`badge ${doc.data.status === "reviewed" || doc.data.status === "verified" ? "is-current" : "needs-review"}`}><span class="badge-kind">{locale === "tr" ? "Editoryal" : "Editorial"}</span>{doc.data.status}</span><span class={`badge ${doc.data.translationStatus === "reviewed" || doc.data.translationStatus === "original" ? "is-synced" : "is-outdated"}`}><span class="badge-kind">{locale === "tr" ? "Çeviri" : "Translation"}</span>{doc.data.translationStatus}</span><span class="badge"><span class="badge-kind">{locale === "tr" ? "Olgunluk" : "Maturity"}</span>{doc.data.maturity}</span><span class="tag">v{doc.data.version}</span><span class="tag">{doc.data.lastReviewedAt.toLocaleDateString(locale === "tr" ? "tr-TR" : "en-US")}</span></div>
      {translationOutdated && <aside class="card" style="transform:none;border-color:var(--warning);margin-bottom:1rem"><strong>{locale === "tr" ? "Çeviri güncellemesi gerekli" : "Translation update required"}</strong><p>{locale.toUpperCase()}: v{doc.data.version} · {translation.data.locale.toUpperCase()}: v{translation.data.version}</p><a href={`/docs/${translation.data.id}/`}>{locale === "tr" ? "Diğer dil sürümünü aç" : "Open the other language version"} →</a></aside>}
      {(doc.data.qualityAttributes.length > 0 || doc.data.applicableDomains.length > 0) && <aside class="card" style="transform:none;margin-bottom:2rem"><strong>{locale === "tr" ? "Sınıflandırma" : "Classification"}</strong><p>{doc.data.qualityAttributes.map(item => <span class="tag">{item}</span>)}{doc.data.applicableDomains.map(item => <span class="tag">{item}</span>)}</p></aside>}
      <Content />
      {sourceRecords.length > 0 && <section><h2>{locale === "tr" ? "Kaynaklar" : "Sources"}</h2><ol>{sourceRecords.map(source => <li><a href={source.url} rel="noreferrer">{source.title}</a> — {source.publisher}, {source.publication_date}</li>)}</ol></section>}
      <section class="card" style="margin-top:3rem"><div class="eyebrow">{locale === "tr" ? "Belge sorumluluğu" : "Document responsibility"}</div><h3>Kenan AY</h3><p>{locale === "tr" ? "Yönetim ve Bilişim Sistemleri Uzmanı" : "Management and Information Systems Specialist"}</p><p>{doc.data.contributors.flatMap(item => item.roles).join(" · ")}</p></section>
      <section id="personal-notes" style="margin-top:3rem"><h2>{locale === "tr" ? "Kişisel notlar" : "Personal notes"}</h2><p class="muted">{locale === "tr" ? "Notlar yalnızca bu tarayıcıda saklanır." : "Notes are stored only in this browser."}</p><textarea id="note-body" rows="4" placeholder="Notunuzu yazın…"></textarea><div class="actions"><button class="primary" id="save-note">Notu kaydet</button><button id="bookmark">☆ Yer imi</button><button id="export-notes">JSON dışa aktar</button><label class="button">JSON içe aktar<input id="import-notes" type="file" accept="application/json" hidden /></label></div><p id="note-message" role="status" aria-live="polite"></p><div id="notes-list"></div></section>
    </article>
  </div>
  <script>
    import { IndexedDbNotesRepository } from "../../modules/notes/adapters/indexed-db-notes";
    const repo = new IndexedDbNotesRepository(); const documentId = document.querySelector("article")?.dataset.documentId || ""; const list = document.querySelector("#notes-list");
    const escapeHtml = (value:string) => value.replace(/[&<>'"]/g, char => ({"&":"&amp;","<":"&lt;",">":"&gt;","'":"&#39;",'"':"&quot;"}[char] || char));
    async function refresh(){const notes=await repo.findByDocumentId(documentId);list!.innerHTML=notes.map(n=>`<div class="card" style="margin-top:1rem"><p>${escapeHtml(n.body)}</p><button data-remove="${n.id}">Sil</button></div>`).join("");}
    document.querySelector("#save-note")?.addEventListener("click",async()=>{const field=document.querySelector<HTMLTextAreaElement>("#note-body");if(!field?.value.trim())return;const now=new Date().toISOString();await repo.save({id:crypto.randomUUID(),documentId,body:field.value.trim(),tags:[],createdAt:now,updatedAt:now});field.value="";await refresh();});
    list?.addEventListener("click",async e=>{const id=(e.target as HTMLElement).dataset.remove;if(id){await repo.remove(id);await refresh();}});
    document.querySelector("#bookmark")?.addEventListener("click",e=>{const key=`bookmark:${documentId}`;const next=localStorage.getItem(key)!=="true";localStorage.setItem(key,String(next));(e.currentTarget as HTMLElement).textContent=next?"★ Yer imi":"☆ Yer imi";});
    document.querySelector("#export-notes")?.addEventListener("click",async()=>{const blob=new Blob([JSON.stringify({schemaVersion:1,project:"software-architecture-atlas",exportedAt:new Date().toISOString(),documentId,notes:await repo.exportAll()},null,2)],{type:"application/json"});const a=document.createElement("a");a.href=URL.createObjectURL(blob);a.download="atlas-notes.json";a.click();URL.revokeObjectURL(a.href);});
    document.querySelector<HTMLInputElement>("#import-notes")?.addEventListener("change",async e=>{const message=document.querySelector("#note-message")!;try{const file=(e.currentTarget as HTMLInputElement).files?.[0];if(!file)return;const payload=JSON.parse(await file.text());if(payload.schemaVersion!==1||payload.project!=="software-architecture-atlas"||!Array.isArray(payload.notes))throw new Error("Geçersiz veya desteklenmeyen yedek biçimi.");const count=await repo.importAll(payload.notes);message.textContent=`${count} not içe aktarıldı.`;await refresh();}catch(error){message.textContent=error instanceof Error?error.message:"İçe aktarma başarısız.";}}); refresh();
  </script>
</BaseLayout>
