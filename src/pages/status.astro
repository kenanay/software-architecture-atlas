---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import taxonomy from "../../data/taxonomy/taxonomy.json";
import requestMap from "../../data/taxonomy/request-map.json";
import standards from "../../data/standards/standards.json";
import rfcs from "../../data/rfcs/rfcs.json";
import terms from "../../data/glossary/glossary.json";
import { calculateTranslationHealth } from "../modules/catalog/domain/translation-health";
const docs = await getCollection("documents");
const health = calculateTranslationHealth(docs);
const covered = new Set(docs.flatMap(doc => doc.data.categories));
const coverage = taxonomy.map(section => {
  const sectionDocs = docs.filter(doc => doc.data.categories.includes(section.id));
  const reviewedCount = sectionDocs.filter(doc => ["reviewed", "verified"].includes(doc.data.status)).length;
  return {...section, implemented: covered.has(section.id), documentCount: sectionDocs.length, reviewedCount, targetDocuments: section.topics.length};
});
const synchronized = health.filter(item => item.status === "synchronized").length;
---
<BaseLayout title="Uygulama ve İçerik Durumu">
  <div class="shell"><div class="eyebrow">Program_info uygulama matrisi</div><h1>Kapsam ve doğrulama durumu</h1><p class="lead">Bu pano platform özelliği ile araştırılmış içerik kapsamını ayırır. Bir kategori şemada mevcut olabilir; içerik incelemesi tamamlanmadan “kapsanmış” sayılmaz.</p>
    <div class="grid"><div class="metric-panel"><div class="metric"><span>Ana bölüm</span><strong>{taxonomy.length}</strong></div></div><div class="metric-panel"><div class="metric"><span>Teknik belge</span><strong>{docs.length}</strong></div></div><div class="metric-panel"><div class="metric"><span>Standart + RFC</span><strong>{standards.length + rfcs.length}</strong></div></div></div>
    <div class="section-head"><div><h2>Çeviri sağlığı</h2><p class="muted">Aynı translationKey altındaki Türkçe ve İngilizce sürümler karşılaştırılır.</p></div><span class="tag">{synchronized}/{health.length} eşzamanlı</span></div>
    <div class="grid">{health.map(item => <article class="card" style="transform:none"><span class={`status ${item.status === "synchronized" ? "reviewed" : "draft"}`}>{item.status}</span><h3>{item.key}</h3><p>TR: {item.trVersion ?? "eksik"} · EN: {item.enVersion ?? "missing"}</p></article>)}</div>
    <div class="section-head" style="margin-top:4rem"><div><h2>İçerik kapsamı</h2><p class="muted">{terms.length} sözlük kaydı mevcut. Eksik bölümler araştırma kuyruğundadır.</p></div></div>
    <div class="grid">{coverage.map(item => <article class="card" style="transform:none"><div class="badge-group"><span class={`badge ${item.reviewedCount > 0 ? "is-current" : "needs-review"}`}><span class="badge-kind">İncelenmiş</span>{item.reviewedCount}/{item.targetDocuments}</span><span class="badge"><span class="badge-kind">Toplam</span>{item.documentCount}</span><span class="tag">{String(item.order).padStart(2,"0")}</span></div><h3>{item.label.tr}</h3><p>{item.topics.slice(0,5).join(" · ")}{item.topics.length > 5 ? " …" : ""}</p><small class="muted">Hedef, bölümdeki planlı konu profili sayısıdır.</small></article>)}</div>
    <div id="taxonomy-map" class="section-head" style="margin-top:4rem"><div><h2>28 gereksinim → 26 kanonik bölüm eşlemesi</h2><p class="muted">Birleştirilen ve bölünen başlıklar açık biçimde izlenir; hiçbir istek başlığı kaybolmaz.</p></div><span class="tag">{requestMap.length} istek</span></div>
    <div style="overflow:auto"><table class="registry-table"><thead><tr><th>#</th><th>İstenen başlık</th><th>Kanonik bölüm</th><th>Eşleme</th></tr></thead><tbody>{requestMap.map(item => <tr><td>{item.requestOrder}</td><td>{item.requested.tr}<br/><small class="muted" lang="en">{item.requested.en}</small></td><td>{item.canonicalIds.map(id => <code>{id}</code>)}</td><td><span class="tag">{item.mapping}</span></td></tr>)}</tbody></table></div>
  </div>
</BaseLayout>
